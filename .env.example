# Copier ce fichier en .env et adapter les valeurs

NODE_ENV=production
JWT_SECRET=CHANGE_ME_SECRET_KEY
JWT_EXPIRES_IN=3600s

POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=scolarite_db
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=admin
DATABASE_PASSWORD=CHANGE_ME_DB_PASSWORD
DATABASE_NAME=scolarite_db

REDIS_HOST=redis
REDIS_PORT=6379

RABBITMQ_URL=amqp://admin:CHANGE_ME_RABBIT_PASSWORD@rabbitmq:5672

KEYCLOAK_SERVER_URL=http://keycloak:8080
KEYCLOAK_REALM=institut-gabriel-rita
KEYCLOAK_CLIENT_ID=backend-client
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_KEYCLOAK_SECRET

TYPESENSE_HOST=typesense
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=CHANGE_ME_TYPESENSE_KEY

WAHA_HOST=waha
WAHA_API_KEY=CHANGE_ME_WAHA_KEY
