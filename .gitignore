# Fichiers et dossiers à ignorer par Git

# Dossier ZKTeco
ZKTeco/
# Dossiers node_modules générés par npm
node_modules/

# Dossier gestscolxp
gestscolxp/

# Environnements / secrets (ne jamais versionner)
.env
**/.env
!.env.example

# Artefacts build
dist/
**/dist/
**/dist/**
build/
**/build/
**/build/**

# Python
__pycache__/
**/__pycache__/
**/__pycache__/**
*.pyc
**/*.pyc

# IDE
.idea/
.vscode/

# Assets/templates de démo (volumineux)
RTL/

# Dumps DB locaux
backup.sql

# Fichiers de contrôle/runtime (ex: gunicorn symlink/fifo)
*.ctl